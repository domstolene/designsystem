{
  "name": "@norges-domstoler/development-utils",
  "version": "2.0.1",
  "description": "Development utilities for developing applications in Norges Domstoler",
  "author": "Elsa team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domstolene/designsystem"
  },
  "sideEffects": [
    "*.css",
    "src/styles/index.ts"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./index.css": "./dist/index.css"
  },
  "homepage": "https://design.domstol.no",
  "scripts": {
    "generate-css-types": "tcm src",
    "build": "pnpm run generate-css-types && tsdown --config-loader unrun --dts",
    "dev": "pnpm run generate-css-types --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "dds",
    "design",
    "development-utils",
    "design system",
    "domstolene",
    "norges domstoler",
    "elsa"
  ],
  "devDependencies": {
    "@norges-domstoler/storybook-components": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/react": "19.2.17",
    "react": "19.2.7",
    "typed-css-modules": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "csstype": "3.2.3",
    "postcss": "^8.5.19",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": "^16 || ^17 || ^18 || ^19"
  },
  "publishConfig": {
    "provenance": true
  }
}
