{
  "name": "@norges-domstoler/dds-formatting",
  "version": "1.6.0",
  "description": "Text formatting functions used in Elsa - domstolenes designsystem",
  "author": "Elsa team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/domstolene/designsystem"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "homepage": "https://design.domstol.no",
  "scripts": {
    "build": "tsdown  --config-loader unrun --dts",
    "build:fast": "tsdown  --config-loader unrun",
    "dev": "pnpm build:fast -- --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui --coverage",
    "coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "keywords": [
    "dds",
    "design",
    "formatting",
    "design system",
    "domstolene",
    "norges domstoler",
    "elsa"
  ],
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "provenance": true
  }
}
